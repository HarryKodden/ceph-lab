# Ceph container image
CEPH_IMAGE=quay.io/ceph/ceph:v18.2.7

# RGW (S3 / RADOS Gateway)
RGW_PORT=7480
RGW_DNS_NAME=localhost
# STS session-token encryption key — must be exactly 16 bytes (AES-128)
RGW_STS_KEY=s3cretSTSkey1234

# Ceph Dashboard (HTTPS)
DASHBOARD_PORT=8080
DASHBOARD_PASSWORD=admin

# S3 demo user
S3_USER=s3user
S3_ACCESS_KEY=s3accesskey12345
S3_SECRET_KEY=s3secretkey12345

# IAM admin user
IAM_UID=iamadmin
IAM_ACCESS_KEY=iamaccess123456
IAM_SECRET_KEY=iamsecret1234567
